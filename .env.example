# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=todo_db
DB_SSLMODE=disable
DB_MAX_CONNECTIONS=25
DB_MIN_CONNECTIONS=5
DB_MAX_IDLE_TIME=5m
DB_MAX_LIFETIME=1h

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json